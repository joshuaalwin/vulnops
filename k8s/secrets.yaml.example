apiVersion: v1
kind: Secret
metadata:
  name: vulnops-db-secret
  namespace: vulnops
type: Opaque
# Replace placeholders with real base64-encoded values before applying.
# To encode: echo -n 'your-value' | base64
# To generate a strong password: openssl rand -base64 32 | base64
#
# Production: use External Secrets Operator + AWS Secrets Manager instead.
# See: https://external-secrets.io/latest/provider/aws-secrets-manager/
data:
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_PASSWORD: <base64-encoded-password>
  POSTGRES_DB: <base64-encoded-dbname>
