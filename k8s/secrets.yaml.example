# DEPRECATED — this manifest is no longer the source of truth for vulnops-db-secret.
#
# The production path is External Secrets Operator + AWS Secrets Manager + EKS Pod Identity.
# The K8s Secret `vulnops-db-secret` is now materialized by the ExternalSecret defined at:
#   bootstrap/external-secrets/external-secret.yaml
#
# See bootstrap/external-secrets/README.md for the install and verification steps.
#
# This file is kept only as a fallback for local development without AWS access
# (e.g. `docker compose up`, or EKS stood up without Secrets Manager). In that case,
# create k8s/secrets.yaml (gitignored) with real base64 values and apply it directly:
#
#   echo -n 'vulnops' | base64           # for POSTGRES_USER / POSTGRES_DB
#   openssl rand -base64 32 | base64     # for POSTGRES_PASSWORD
#
apiVersion: v1
kind: Secret
metadata:
  name: vulnops-db-secret
  namespace: vulnops
type: Opaque
data:
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_PASSWORD: <base64-encoded-password>
  POSTGRES_DB: <base64-encoded-dbname>
